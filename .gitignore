# Keep folder structure, ignore contents
data/*
!data/layer2_dynamic_events/
data/layer2_dynamic_events/**/*
!data/layer2_dynamic_events/**/
!data/layer2_dynamic_events/**/.gitkeep
!data/layer2_dynamic_events/**/README.md
!data/layer2_dynamic_events/manifests/*.json
!data/layer2_dynamic_events/manifests/*.yaml
!data/layer2_dynamic_events/manifests/*.yml
results/*
models/*
!.gitkeep

# Ignore hidden files/dirs
.*
# Exception: keep .gitignore itself
!.gitignore
!data/layer2_dynamic_events/**/.gitkeep

# Ignore large generated data
bin/
logs/
lancedb_data/
chromadb_data/
chromadb_hnsw_sweep_data/
lancedb_hnsw_sweep_data/
chromadb_batch_ids.json
cpp/build/

# Python bytecode
__pycache__/
*.pyc

# Runtime files
.server.pid
*.vlog
*.mem
*.log
